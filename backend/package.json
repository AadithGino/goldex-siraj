{
  "name": "goldex-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "check": "npm run lint && npm test",
    "create-owner": "node scripts/create-owner.js",
    "seed-catalog": "node scripts/seed-catalog.js",
    "repair-rate-effective-at": "node scripts/repair-rate-effective-at.js",
    "coupon:reconcile": "node scripts/reconcile-coupon-usage.js",
    "coupon:reconcile:dry": "node scripts/reconcile-coupon-usage.js --dry-run",
    "coupon:repair-redemptions": "node scripts/repair-coupon-redemptions.js",
    "coupon:repair-redemptions:dry": "node scripts/repair-coupon-redemptions.js --dry-run",
    "wallet:backfill": "node scripts/backfill-wallet-accounts.js",
    "wallet:backfill:dry": "node scripts/backfill-wallet-accounts.js --dry-run",
    "migrate:indexes": "node scripts/migrate-indexes.js",
    "migrate:indexes:dry": "node scripts/migrate-indexes.js --dry-run",
    "schemes:backfill-payment-refs": "node scripts/backfill-scheme-payment-refs.js --apply",
    "schemes:backfill-payment-refs:dry": "node scripts/backfill-scheme-payment-refs.js",
    "coupon:backfill-usage": "node scripts/backfill-coupon-customer-usage.js",
    "coupon:backfill-usage:dry": "node scripts/backfill-coupon-customer-usage.js --dry-run",
    "uploads:cleanup-return-proofs": "node scripts/cleanup-return-proofs.js",
    "uploads:cleanup-return-proofs:dry": "node scripts/cleanup-return-proofs.js --dry-run",
    "returns:backfill-reservations": "node scripts/backfill-reserved-return-qty.js --apply",
    "returns:backfill-reservations:dry": "node scripts/backfill-reserved-return-qty.js",
    "cart:migrate-customization-index": "node scripts/migrate-cart-customization-index.js --apply",
    "cart:migrate-customization-index:dry": "node scripts/migrate-cart-customization-index.js",
    "brands:backfill-responsive-logos": "node scripts/backfill-brand-responsive-logos.js --apply",
    "brands:backfill-responsive-logos:dry": "node scripts/backfill-brand-responsive-logos.js",
    "products:backfill-primary-images": "node scripts/backfill-product-primary-images.js --apply",
    "products:backfill-primary-images:dry": "node scripts/backfill-product-primary-images.js",
    "stones:audit-pricing:dry": "node scripts/audit-product-stones.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "argon2": "^0.41.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
