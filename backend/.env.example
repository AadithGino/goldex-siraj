NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/goldex
CLIENT_ORIGINS=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECURE=false
# Cross-origin FE (Netlify/localhost) + API host: set COOKIE_SECURE=true and
# COOKIE_SAMESITE=none (None is auto when COOKIE_SECURE=true).
# COOKIE_SAMESITE=none
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_PROVIDER=console
# Leave these unset unless OTP_PROVIDER=http
# OTP_PROVIDER_API_KEY=
# OTP_PROVIDER_URL=
# Development/testing only: when true (and OTP_PROVIDER=console, NODE_ENV!=production),
# send-OTP responses may include test_otp for the local UI. Forbidden in production.
SHOW_TEST_OTP=false

# Storage: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=uploads
# Local mirror URL, or a CDN / CloudFront base when using S3
STORAGE_PUBLIC_URL=http://localhost:4000/uploads

# Preferred AWS S3 settings (used when STORAGE_DRIVER=s3)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
# Root prefix only — tenant + public/private folders are added automatically
AWS_S3_PREFIX=jewellers
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional custom endpoint (MinIO / path-style). Leave unset for real AWS.
# AWS_S3_ENDPOINT=

# Tenant folder becomes {JEWELLERY_ID}-{JEWELLERY_SLUG} → goldex1-jewellery
# Final keys: jewellers/goldex1-jewellery/public/product-images/...
#             jewellers/goldex1-jewellery/private/product-certificates/...
JEWELLERY_ID=goldex1
JEWELLERY_NAME="Goldex Jewellery"
JEWELLERY_SLUG=jewellery
# Optional override instead of id-slug:
# JEWELLERY_FOLDER=goldex1-jewellery

# Legacy aliases (still accepted if AWS_* are unset)
# S3_REGION=
# S3_BUCKET=
# S3_PREFIX=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

MAX_UPLOAD_BYTES=10485760
LOG_LEVEL=info
