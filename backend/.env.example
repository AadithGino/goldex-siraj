NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/goldex
CLIENT_ORIGINS=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECURE=false
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_PROVIDER=console
# Leave these unset unless OTP_PROVIDER=http
# OTP_PROVIDER_API_KEY=
# OTP_PROVIDER_URL=
# Development/testing only: when true (and OTP_PROVIDER=console, NODE_ENV!=production),
# send-OTP responses may include test_otp for the local UI. Forbidden in production.
SHOW_TEST_OTP=false
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=uploads
STORAGE_PUBLIC_URL=http://localhost:4000/uploads
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MAX_UPLOAD_BYTES=10485760
LOG_LEVEL=info
